<?php namespace ProcessWire;

class ProcessTrackingScriptsConfig extends Process {

    public function ___execute() {
        $modules = $this->wire('modules');
        $input = $this->wire('input');
        $targetModule = 'TrackingScripts';

        $savedConfig = $modules->getConfig($targetModule);
        if (!is_array($savedConfig)) $savedConfig = [];

        $form = $this->buildForm($savedConfig);

        if ($input->post('submit_save')) {
            $form->processInput($input->post);
            $newConfig = $savedConfig;
            foreach ($this->getFieldDefinitions() as $fieldsetKey => $fieldset) {
                foreach ($fieldset['children'] as $name => $def) {
                    $newConfig[$name] = $form->getChildByName($name)->val();
                }
            }
            $modules->saveConfig($targetModule, $newConfig);
            $this->message($this->_('Configuración guardada'));
            $this->wire('session')->redirect($this->wire('page')->url);
        }

        return $form->render();
    }

    protected function buildForm(array $savedConfig): InputfieldForm {
        $modules = $this->wire('modules');
        $root = $this->wire('config')->paths->root;
        $form = $modules->get('InputfieldForm');
        $form->attr('method', 'post');
        $form->attr('action', './');

        foreach ($this->getFieldDefinitions() as $fieldsetKey => $fieldset) {
            $fs = $modules->get('InputfieldFieldset');
            $fs->label = $fieldset['label'];
            if (isset($fieldset['columnWidth'])) $fs->columnWidth = $fieldset['columnWidth'];

            foreach ($fieldset['children'] as $name => $def) {
                switch ($def['type']) {
                    case 'textarea': $type = 'InputfieldTextarea'; break;
                    case 'select':   $type = 'InputfieldSelect'; break;
                    case 'checkbox': $type = 'InputfieldCheckbox'; break;
                    default:         $type = 'InputfieldText'; break;
                }
                $f = $modules->get($type);
                $f->attr('name', $name);
                $f->label = $def['label'];
                if (isset($def['description'])) $f->description = $def['description'];
                if (isset($def['columnWidth'])) $f->columnWidth = $def['columnWidth'];
                if (isset($def['rows'])) $f->rows = $def['rows'];
                if (isset($def['options']) && $type === 'InputfieldSelect') {
                    $f->addOptions($def['options']);
                }

                // Load value: config first, then file fallback for txt fields
                $val = $savedConfig[$name] ?? $def['value'];
                if (empty($val) && isset($def['file'])) {
                    $path = $root . $def['file'];
                    if (is_file($path)) $val = file_get_contents($path);
                }
                $f->attr('value', $val);

                if ($type === 'InputfieldCheckbox' && $val) {
                    $f->attr('checked', 'checked');
                }

                $fs->add($f);
            }

            $form->add($fs);
        }

        $submit = $modules->get('InputfieldSubmit');
        $submit->attr('name', 'submit_save');
        $submit->attr('value', $this->_('Guardar'));
        $form->add($submit);

        return $form;
    }

