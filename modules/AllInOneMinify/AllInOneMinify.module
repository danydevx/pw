// @codingStandardsIgnoreLine

// JShrink minification library for javascript files
require_once __DIR__ . '/lib/tedivm/jshrink/src/JShrink/Minifier.php';

// URL rewriting library - rewrite relative to root-relative URIs
require_once __DIR__ . '/lib/mrclay/minify/lib/Minify/CSS/UriRewriter.php';

// LESS compiler library
require_once __DIR__ . '/lib/wikimedia/less.php/lessc.inc.php';


class AllInOneMinify extends WireData implements Module, ConfigurableModule {

	public const CACHEDIR  = 'aiom'; // name of the cache folder(s), no leading/trailing slashes
	public const MIN_CACHE_LIFETIME = 60; // in seconds, 1 minute
	public const MAX_CACHE_LIFETIME = 31536000; // in seconds, 1 year
	public const DEFAULT_CACHE_LIFETIME = 2419200; // in seconds, 28 days
	public const DEBUG = true; // for internal debugging
	public const MODULENAME = 'AllInOneMinify'; // to save some calls

	/**
	 * Module info
	 *
	 * @return array<string,mixed>
	 *
	 */
	public static function getModuleInfo() {

		return [
			'title' => __('AIOM+ (All In One Minify) for CSS, LESS, JS and HTML'),
			'version' => '4.1.0',
			'author' => 'David Karich & Conclurer GbR, matjazpotocnik, kixe, Philzen, TomS, gingebaker, janKir, gr4y and others',
			'summary' => __('AIOM+ (All In One Minify) boosts website performance by parsing, minifying, and combining CSS, LESS, and JS into single, optimized files. By reducing server requests and shrinking file sizes, AIOM+ cuts loading times and bandwidth usage. It also offers HTML minification and enhanced template caching to significantly accelerate your site.'),
			'href' => 'https://github.com/matjazpotocnik/ProcessWire-AIOM-All-In-One-Minify',
			'singular' => true,
			'autoload' => true,
			'requires' => 'ProcessWire>=3.0.118, PHP>=8.1.0',
		];
	}

	/**
	 * If template uses https protocol
	 * @var bool
	 */
	protected static $templateUseSSL;

	/**
	 * This module config data
	 * @var array<string,string>
	 */
	protected static $configData = [];

	/**
	 * This module default config data
	 * @var array<string,string>
	 */
	protected static $configDataDefault = [];

	/**
	 * Cache folder with minified CSS/JS files
	 * @var string
	 */
	protected static $assetsCacheDir;

	/**
	 * Cache folder for page caches
	 * @var string
	 */
	protected static $pagesCacheDir;

	/**
	 * Cache folder for "frontend" cache.json files
	 * @var string
	 */
	protected static $aiomCacheDir;

	/**
	 * Construct and set default configuration
	 *
	 * @return void
	 */
	public function __construct() {

		self::$configDataDefault = [
			'stylesheet_prefix' => 'css_',
			'javascript_prefix' => 'js_',
			'max_cache_lifetime' => (string) self::DEFAULT_CACHE_LIFETIME,
			'html_minify' => '',
			'html_minify_mode' => 'safe',
			'css_minify' => '',
			'css_source_map' => '1',
			'js_minify' => '',
			'development_mode' => '',
			'directory_traversal' => '',
			'domain_sharding' => '',
			'domain_sharding_ssl' => '',
			'cache_enable' => '',
			'template_files' => '',
		];

		/** @var Modules $modules */
		$modules = wire()->modules;
		$paths = wire()->config->paths;
		/** @var array<string,string> $cfg */
		$cfg = $modules->getConfig($this);

		self::$configData = $this->sanitizeData($cfg);
		self::$assetsCacheDir = $paths->assets . self::CACHEDIR . '/';           // /site/assets/aiom/
		self::$aiomCacheDir =   $paths->cache  . self::CACHEDIR . '/';           // /site/assets/cache/aiom/
		self::$pagesCacheDir =  $paths->cache  . PageRender::cacheDirName . '/'; // /site/assets/cache/Page/

	}

	/**
	 * Initializes the module by registering class aliases so that public methods
	 * AIOM::JS() and AIOM::CSS() can be used in both namespaced and non-namespaced
	 * templates.
	 *
	 * @return void
	 */
	public function init() {
  	if (!class_exists('AIOM', false) && class_exists('ProcessWire\\AIOM', false)) {
    	class_alias('ProcessWire\\AIOM', 'AIOM');
  	}
  	if (!class_exists('AllInOneMinify', false) && class_exists('ProcessWire\\AllInOneMinify', false)) {
    	class_alias('ProcessWire\\AllInOneMinify', 'AllInOneMinify');
  	}
	}

	/**
	 * Create a new tab (WireTabs) or a plain fieldset, depending on $useTabs.
	 *
	 * @param bool $useTabs True for a tab (WireTab), false for a plain fieldset.
	 * @param string $label Tab/fieldset label.
	 * @param int|false $collapsed Collapsed state for fieldset.
	 * @return InputfieldWrapper|InputfieldFieldset
	 */
	private function newTab($useTabs, $label, $collapsed = false) {
		static $n = 0;
		$n++;

		if ($useTabs) {
			//$fieldset = wire()->modules->get('InputfieldWrapper');
			//$fieldset = new InputfieldWrapper();
			//https://processwire.com/talk/topic/24934-using-tabs-wiretabs-in-a-module-config/?tab=comments#comment-216968
			$fieldset = wire(new InputfieldWrapper());
			/** @var InputfieldWrapper $fieldset */
			$fieldset->attr('title', $label);
			$fieldset->attr('class', 'WireTab');
		} else {
			/** @var InputfieldFieldset $fieldset */
			$fieldset = wire()->modules->get('InputfieldFieldset');
			$fieldset->label = $label;
			if ($collapsed !== false) $fieldset->collapsed = $collapsed;
		}

		$fieldset->attr('id', "AIOMtab-$n");

		return $fieldset;
	}

	/**
	 * Sanitize & normalize module config data with defaults.
	 *
	 * @param array<string,string> $data
	 * @return array<string,string>
	 */
	private function sanitizeData($data) {
		if (empty($data)) return self::$configDataDefault;

		$sanitizer = wire()->sanitizer;
		$originalData = $data;

		$data['max_cache_lifetime'] = (string) $this->sanitizeNumericCacheTime($data['max_cache_lifetime']);
		$data['stylesheet_prefix'] = $sanitizer->name($data['stylesheet_prefix']);
		$data['javascript_prefix'] = $sanitizer->name($data['javascript_prefix']);
		$data['domain_sharding'] = $this->validateURL($data['domain_sharding']);
		$data['domain_sharding_ssl'] = $this->validateURL($data['domain_sharding_ssl']);
		$data['template_files'] = trim($data['template_files']);
		$htmlMinifyMode = $data['html_minify_mode'] ?? 'safe';
		$data['html_minify_mode'] = in_array($htmlMinifyMode, ['safe', 'legacy'], true)
			? $htmlMinifyMode
			: 'safe';

		$data = array_merge(self::$configDataDefault, $data);

		if (json_encode($data) != json_encode($originalData)) {
			wire()->modules->saveConfig($this, $data);
		}

		return $data;
	}

	/**
	 * Configure the input fields for the admin backend.
	 *
	 * @param array<string,string> $data Module data from the database.
	 * @return InputfieldWrapper
	 */
	public function getModuleConfigInputfields($data) {
		if (empty($data)) $data = self::$configDataDefault;

		$labelSettings = __('Module Settings');
		$labelCaching = __('Caching');
		$labelMinifying = __('Minifying');
		$labelUsage = __('Usage');
		$labelReadme = __('Readme');

		/** @var Modules $modules */
		$modules = wire()->modules;
		$config = wire()->config;

		$useTabs = $modules->isInstalled('JqueryWireTabs');

		if ($useTabs) {
			// since PW 3.0.170 children inside InputfieldWrapper don't get style="width: xx%"
			// so if tabs are used, the workaround is to use ukGrid layout that use uk-width-* classes
			$adminTheme = $config->wire('adminTheme');
			if ($adminTheme instanceof WireData) {
				$adminTheme->set('ukGrid', true);
			}

			$modules->get('JqueryWireTabs');

			/** @var InputfieldWrapper $wrapper1 */
			$wrapper1 = wire(new InputfieldWrapper());

			/** @var InputfieldFieldset $wrapper */
			$wrapper = $modules->get('InputfieldFieldset');
			$wrapper->label = $labelSettings;
			$wrapper->icon = 'gears';

			//this is placeholder for wiretabs
			/** @var InputfieldMarkup $wiretabsID */
			$wiretabsID = $modules->get('InputfieldMarkup');
			$wiretabsID->id = 'wrapAIOMtabs';
			$wiretabsID->entityEncodeText = false;

			//prepare wiretabs links in advance
			/*
			$links['AIOMtab-1'] = $labelCaching;
			$links['AIOMtab-2'] = $labelMinifying;
			$links['AIOMtab-3'] = $labelUsage;
			$links['AIOMtab-4'] = $labelReadme;
			$wiretabs = $modules->get('JqueryWireTabs');
			$tabList = $wiretabs->renderTabList($links, ['id' => 'AIOMlinks']);
			$wiretabsID->value = "<div id='AIOMtabs'>$tabList</div>";
			*/

			//or let jQuery.WireTabs() create wiretabs links
			//$wiretabsID->value = "<div id='AIOMtabs'></div>";

			//hijacking already used placeholder in ProcessModule.js
			//so AllInOneMinify.js is not needed
			$wiretabsID->value = "<div id='modules_form'></div>";

			$wrapper->add($wiretabsID);

			$wrapper1->add($wrapper);
		} else {
			$wrapper = wire(new InputfieldWrapper());
			/** @var InputfieldWrapper $wrapper */
		}

		$this->addCachingSection($wrapper, $data, $useTabs, $labelCaching);
		$this->addMinifyingSection($wrapper, $data, $useTabs, $labelMinifying);
		$this->addUsageSection($wrapper, $useTabs, $labelUsage);
		$this->addReadmeSection($wrapper, $useTabs, $labelReadme);

		return $useTabs ? $wrapper1 : $wrapper;
	}

	/**
	 * Add the caching settings section to the module config UI.
	 *
	 * @param array<string,string> $data
	 * @return void
	 */
	private function addCachingSection(InputfieldWrapper $wrapper, array $data, bool $useTabs, string $labelCaching): void {
		/** @var Modules $modules */
		$modules = wire()->modules;
		$templates = wire()->templates;
		$config = wire()->config;

		$fieldset = $this->newTab($useTabs, $labelCaching); //AIOMtab-1

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'cache_enable';
		$field->label = __('AIOM+ template caching');
		$field->description = __('Check this box to enable AIOM+ template caching.');
		$field->label2 = __('Enable AIOM+ template caching');
		$field->columnWidth = 33;
		$field->value = $data['cache_enable'];
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->notes = __('This option enhances core template caching. Minifying/caching of JS and CSS files can be set up independently.');
		$indexFile = (string) file_get_contents($config->paths->root . 'index.php');
		if (strpos($indexFile, 'AIOMcache.php') === false) $field->notes .= "\n\n" . __('Looks like caching is not enabled in index.php. Consult README.md for instructions.');
		$fieldset->add($field);

		/** @var InputfieldTextarea $field */
		$field = $modules->get('InputfieldTextarea');
		$field->name = 'template_files';
		$field->label = 'Additional cache clear options';
		$field->rows = 3;
		$field->columnWidth = 34;
		$field->description = __('This option lets you specify files that are checked against template cache files. ') .
													__('When these files are newer than files in the cache, cache files are cleared.');
		$field->notes = __('Enter each file on its own line. Files are relative to /site/templates/ folder. Alternate/prepend/append template files specify as {template_files} and {config_template_files}.');
		$field->value = $data['template_files'];
		//$field->collapsed = Inputfield::collapsedBlank;
		$fieldset->add($field);

		/** @var InputfieldMarkup $field */
		$field = $modules->get('InputfieldMarkup');
		$field->columnWidth = 33;
		$field->label = __('Cache control');
		$field->description = __('Here you can delete all AIOM+ cache files.').'<br><br>';
		$field->entityEncodeText = false;
		//commented due to possible performance reasons
		//$cacheInfoPage = self::getNumberOfPagesCacheFiles();
		//$cacheInfoAiom = self::getNumberOfAiomCacheFiles();
		//$field->value = sprintf(__('AIOM cache files: %s | Size: %s'), $cacheInfoAiom['numberOfFiles'], $cacheInfoAiom['bytesTotal']);
		//$field->value .= '<br>'.sprintf(__('Template cache files: %s | Pages: %s | Size: %s'), $cacheInfoPage['numberOfFiles'], $cacheInfoPage['numberOfPages'],  $cacheInfoPage['bytesTotal']).'<br>';

				/** @var InputfieldButton $field_button */
				$field_button        = $modules->get('InputfieldButton');
				$field_button->name  = 'empty_page_cache';
				$field_button->value = __('Empty cache');
				$field_button->href  = 'edit?name=' . self::MODULENAME . '&pagecache=clear';

		$field->add($field_button);
		$fieldset->add($field);

		/** @var MarkupAdminDataTable $table */
		$table = $modules->get('MarkupAdminDataTable');
		$table->setEncodeEntities(false);
		//$table->set('resizable', true);
		$table->addClass('uk-margin-remove-top');
		$table->headerRow([
			__('Template name'),
			__('Total pages'),
			__('Cache time'),
			__('Clear behavior'),
			__('Cache rendering'),
		]);

		$labelsTpl = [
			Template::cacheExpireNone => __('None'),
			Template::cacheExpirePage => __('Self'),
			Template::cacheExpireSite => __('Site'),
			Template::cacheExpireParents => __('Parents'),
			Template::cacheExpireSpecific => __('Specific pages'),
			Template::cacheExpireSelector => __('Selector'),
		];
		$labelsFor = [
			0 => __('for guests only'),
			1 => __('for guests and logged-in users'),
		];
		$numTemplates = 0;

		foreach ($templates as $template) {
			/** @var Template $template */
			if ($template->cache_time <= 0) continue;

			$numTemplates++;
			$clearBehaviorLabel = $this->buildTemplateClearBehaviorLabel($template, $labelsTpl);
			$userScopeLabel = $labelsFor[$template->useCacheForUsers] ?? '???';
			$cacheTimeLabel = $template->cache_time . ' (' . self::seconds2human($template->cache_time) . ')';
			$templateNameLabel = '<b>' . $template->name . '</b>';

			$table->row([
				//[$templateNameLabel => '../../setup/templates/edit?id=' . $template->id . '#tab_cache'], //not working due to a bug
				"<a href='../../setup/template/edit?id=" . $template->id . "#tab_cache'>" . $templateNameLabel . "</a>",
				$templates->getNumPages($template),
				$cacheTimeLabel,
				$clearBehaviorLabel,
				$userScopeLabel,
			]);
		}

		/** @var InputfieldMarkup $field */
		$field = $modules->get('InputfieldMarkup');
		$field->name = 'cache_templates';
		$field->label = __('Templates with enabled caching');
		//$field->entityEncodeText = false;
		if ($numTemplates === 0) {
			$field->description = __('There are no templates with enabled caching.');
		} else {
			$field->value = $table->render();
			$field->description = __('This is a list of templates with enabled caching. Click on the template name to change the cache settings.');
		}
		$field->notes = __('Set the caching options for other templates in [Templates Setup](../../setup/template/).');
		$fieldset->add($field);

		$wrapper->add($fieldset);
	}

	/**
	 * Build label for template cache clear behavior.
	 *
	 * @param array<int|string,string> $labelsTpl
	 * @return string
	 */
	private function buildTemplateClearBehaviorLabel(Template $template, array $labelsTpl): string {
		$label = $labelsTpl[$template->cacheExpire] ?? '???';

		if ($template->cacheExpire === Template::cacheExpireSpecific) {
			$label .= ' (' . implode(',', $template->cacheExpirePages) . ')';
		}

		if ($template->cacheExpire === Template::cacheExpireSelector) {
			$label .= ' (' . $template->cacheExpireSelector . ')';
		}

		return $label;
	}

	/**
	 * Add the minifying settings section to the module config UI.
	 *
	 * @param array<string,string> $data
	 * @return void
	 */
	private function addMinifyingSection(InputfieldWrapper $wrapper, array $data, bool $useTabs, string $labelMinifying): void {
		/** @var Modules $modules */
		$modules = wire()->modules;

		$fieldset = $this->newTab($useTabs, $labelMinifying); //AIOMtab-2

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'html_minify';
		$field->label = __('HTML minify');
		$field->columnWidth = 33;
		$field->value = $data['html_minify'];
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->description = __('Enable to minify HTML source code.');
		$fieldset->add($field);

		/** @var InputfieldSelect $field */
		$field = $modules->get('InputfieldSelect');
		$field->name = 'html_minify_mode';
		$field->label = __('HTML minify mode');
		$field->columnWidth = 33;
		$field->addOption('safe', __('Safe (recommended)'));
		$field->addOption('legacy', __('Legacy (original AIOM)'));
		$field->attr('value', $data['html_minify_mode'] ?? 'safe');
		$field->description = __('Safe mode uses conservative rules (MinifyPageRender style). Legacy mode uses original AIOM behavior and can break modern HTML/JS in some cases.');
		$fieldset->add($field);

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'css_minify';
		$field->label = __('CSS minify');
		$field->columnWidth = 34;
		$field->value = $data['css_minify'];
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->description = __('Enable to minify CSS files in HTML source code.');
		$fieldset->add($field);

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'css_source_map';
		$field->label = __('CSS source map');
		$field->columnWidth = 33;
		$field->value = $data['css_source_map'] ?? '';
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->description = __('Generate a .map file for each AIOM+ generated CSS file and append sourceMappingURL.');
		$fieldset->add($field);

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'js_minify';
		$field->label = __('JS minify');
		$field->columnWidth = 33;
		$field->value = $data['js_minify'];
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->description = __('Enable to minify JS files in HTML source code.');
		$fieldset->add($field);

		/** @var InputfieldText $field */
		$field = $modules->get('InputfieldText');
		$field->name = 'max_cache_lifetime';
		$field->label = __('Lifetime');
		$field->columnWidth = 33;
		$field->value = $data['max_cache_lifetime'];
		$field->description = __('The max. lifetime of JS/CSS files in seconds, min. 60, max. 31536000 seconds (1 year).');
		$fieldset->add($field);

		/** @var InputfieldText $field */
		$field = $modules->get('InputfieldText');
		$field->name = 'stylesheet_prefix';
		$field->label = __('CSS prefix');
		$field->columnWidth = 34;
		$field->value = $data['stylesheet_prefix'];
		$field->description = __('The prefix of the generated combined stylesheet file. Allowed characters: "A-Z, a-z, 0-9 and _ -".');
		$fieldset->add($field);

		/** @var InputfieldText $field */
		$field = $modules->get('InputfieldText');
		$field->name = 'javascript_prefix';
		$field->label = __('JS prefix');
		$field->columnWidth = 33;
		$field->value = $data['javascript_prefix'];
		$field->description = __('The prefix of the generated combined javascript file. Allowed characters: "A-Z, a-z, 0-9 and _ -".');
		$fieldset->add($field);

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'development_mode';
		$field->label = __('Development mode');
		$field->columnWidth = 33;
		$field->value = $data['development_mode'];
		if ((int) $field->value === 1) {
			$field->attr('checked', 'checked');
		}
		$field->description = __('Enable development mode to prevent browser caching and not minify HTML source code or CSS/JS files.');
		$fieldset->add($field);

		/** @var InputfieldCheckbox $field */
		$field = $modules->get('InputfieldCheckbox');
		$field->name = 'directory_traversal';
		$field->label = __('Allow Directory Traversal');
		$field->columnWidth = 34;
		$field->value = $data['directory_traversal'];
		if ((int) $field->value === 1) $field->attr('checked', 'checked');
		$field->description = __('Enable the directory traversal option to make it possible to add files from outside of the template folders. (../)');
		$fieldset->add($field);

		$cacheInfo = self::getNumberOfAssetsCacheFiles();
		/** @var InputfieldMarkup $field */
		$field = $modules->get('InputfieldMarkup');
		$field->columnWidth = 33;
		$field->label = __('Cache control');
		$field->description = __('Here you can delete minified JS and CSS files. Note: this will also empty the template cache!').'<br><br>';
		$field->entityEncodeText = false;
		$field->value = sprintf(__('Minified files: %s | Size: %s'), $cacheInfo['numberOfFiles'], $cacheInfo['bytesTotal']);

				/** @var InputfieldButton $field_button */
				$field_button        = $modules->get('InputfieldButton');
				$field_button->name  = 'empty_cache';
				$field_button->value = __('Empty cache');
				$field_button->href  = 'edit?name=' . self::MODULENAME . '&cache=clear';

		$field->add($field_button);
		$fieldset->add($field);

		/** @var InputfieldText $field */
		$field = $modules->get('InputfieldText');
		$field->name = 'domain_sharding';
		$field->label = __('Domain sharding');
		$field->columnWidth = 50;
		$field->value = $data['domain_sharding'];
		$field->description = __('To speed up the download of stylesheets and javascripts, this can be made available via a second subdomain (parallel download and Cookieless domain). The second subdomain (e.g., static.mysite.com) must also point to the web root directory of ProcessWire. Leave the field blank to disable this option.');
		$fieldset->add($field);

		/** @var InputfieldText $field */
		$field = $modules->get('InputfieldText');
		$field->name = 'domain_sharding_ssl';
		$field->label = __('Domain sharding (SSL)');
		$field->columnWidth = 50;
		$field->value = $data['domain_sharding_ssl'];
		$field->description = __('To speed up the download of stylesheets and javascripts, this can be made available via a second subdomain (parallel download and Cookieless domain). The second subdomain (e.g., static.mysite.com) must also point to the web root directory of ProcessWire. Leave the field blank to disable this option.');
		$fieldset->add($field);

		$wrapper->add($fieldset);
	}

	/**
	 * Add the usage section to the module config UI.
	 *
	 * @return void
	 */
	private function addUsageSection(InputfieldWrapper $wrapper, bool $useTabs, string $labelUsage): void {
		/** @var Modules $modules */
		$modules = wire()->modules;
		$config = wire()->config;
		$modulePath = $config->paths->siteModules . self::MODULENAME . '/';

		$fieldset = $this->newTab($useTabs, $labelUsage, Inputfield::collapsedNoLocked); //AIOMtab-3

		/** @var InputfieldMarkup $field */
		$field = $modules->get('InputfieldMarkup');
		$field->label = __('How to use AIOM+');
		$field->description = __('Quick introduction to the module and how you use it. See README.md for full documentation.');
		$field->markupText = (string) file_get_contents($modulePath . 'doc/how-to-use.html');
		$fieldset->add($field);

		$wrapper->add($fieldset);
	}

	/**
	 * Add the readme section to the module config UI.
	 *
	 * @return void
	 */
	private function addReadmeSection(InputfieldWrapper $wrapper, bool $useTabs, string $labelReadme): void {
		/** @var Modules $modules */
		$modules = wire()->modules;
		$config = wire()->config;
		$modulePath = $config->paths->siteModules . self::MODULENAME . '/';

		$fieldset = $this->newTab($useTabs, $labelReadme, Inputfield::collapsedNoLocked); //AIOMtab-4

		/** @var InputfieldMarkup $field */
		$field = $modules->get('InputfieldMarkup');
		$field->label = __('Readme for AIOM+');
		$readme = (string) file_get_contents($modulePath . 'README.md');
		$readme = $field->entityEncode($readme, Inputfield::textFormatMarkdown);
		$field->value = $readme;
		$fieldset->add($field);

		$wrapper->add($fieldset);
	}

	/**
	 * Create the cache folder in the /site/assets/.
	 *
	 * @return void
	 * @throws WireException
	 */
	public function ___install() {
		$dir = self::$assetsCacheDir;

		if (!is_dir($dir) && wireMkdir($dir) === false) {
			throw new WireException("The cache folder $dir could not be created.");
		}

		/** @var PageRender $pr */
		$pr = wire()->modules->get('PageRender'); //this also install a module
		if (!$pr) {
			throw new WireException('PageRender module could not be installed.');
		}
	}

	/**
	 * Remove the cache folders /site/assets/aiom/ and /site/assets/cache/aiom/
	 *
	 * @return void
	 */
	public function ___uninstall() {
		$paths = [self::$assetsCacheDir, self::$aiomCacheDir];

		foreach ($paths as $dir) {
			if (!is_dir($dir)) continue;
			wireChmod($dir);
			if (wireRmdir($dir, true) === false) {
				$this->warning("The folder $dir could not be removed.");
			}
		}

	}

	/**
	 * Set hooks
	 *
	 * @return void
	 */
	public function ready() {
		$config = wire()->config;
		$input = wire()->input;
		$page = wire()->page;
		/** @var Template $template */
		$template = $page->template;

		if ($input->get('cache') === 'clear' && $template->name === 'admin') self::clearAssetsCacheFromBackend();
		if ($input->get('pagecache') === 'clear' && $template->name === 'admin') self::clearAiomCacheFromBackend();

		if ($input->get('name') === $this->className()) {
			//js needed only if using WireTabs with custom wiretabid
			//$config->scripts->add($config->urls->siteModules . self::MODULENAME . '/' . self::MODULENAME . '.js');//?v=' . time());
			$config->styles->add($config->urls->siteModules . self::MODULENAME . '/' . self::MODULENAME . '.css');//?v=' . time());
		}

		// Check if template files are newer than cache file
		if ($template->name !== 'admin' && $template->cache_time > 0 && self::$configData['template_files'] !== '') {
			$this->addHookBefore('Page::render', $this, 'checkTemplateFiles');
		}

		if ((
				self::$configData['html_minify'] != 1 &&
				self::$configData['css_minify'] != 1 &&
				self::$configData['js_minify'] != 1 &&
				self::$configData['cache_enable'] != 1) ||
				//self::$configData['development_mode'] == 1 || //should development mode affect caching?
				($template->name === 'admin' || $template->name === 'user')) return;

		if (self::$configData['cache_enable'] == 1) {
			if (!is_file(self::$aiomCacheDir . 'aiom.enabled')) @file_put_contents(self::$aiomCacheDir . 'aiom.enabled', time());
		} else {
			if (is_file(self::$aiomCacheDir . 'aiom.enabled')) @unlink(self::$aiomCacheDir . 'aiom.enabled');
		}

		// Check if the current template requires SSL.
		$this->addHookBefore('Page::render', $this, 'checkSSL');

		// Add a hook that is called after rendering the page and minify the
		// generated html source code, inlined CSS/JS files and create a cache file.
		$this->addHookAfter('Page::render', $this, 'HTML', ['priority' => 199]);

		// Check if already cached files longer than the configured time exist.
		// If so, remove those files.
		self::clearAssetsCache();
	}


	/**
	 * Minifies, combines, and caches one or more JavaScript files.
	 *
	 * Accepts a single JavaScript path or an array of them. Each file is minified,
	 * concatenated with others, and written into a single cached asset file.
	 * Returns the public URL to the generated asset.
	 *
	 * @param string|array<int,string>|FilenameArray $javascripts
	 *     A JavaScript file path or array of file paths relative to the templates
	 *     directory.
	 * @return string
	 *     Public URL to the combined and minified JavaScript file eg.
	 *     `/site/assets/aiom/js_1f259989ada30d54ea095abce48b228c.js`
	 * @example
	 *     <script src="<?= AIOM::JS('app.js') ?>"></script>
	 * @example
	 *     // Combine two javascripts
	 *     echo "<script src='" . AIOM::JS(['js/vendor.js', 'js/main.js']) . "'></script>";
	 * @example
	 *     // Using PW config scripts (FilenameArray)
	 *     <script src="<?= AIOM::JS($config->scripts) ?>"></script>
	 * @example
	 *     // Using custom FilenameArray
	 *     $js = new FilenameArray();
	 *     $js->add('js/vendor.js');
	 *     $js->add('js/main.js');
	 *     echo "<script src='" . AIOM::JS($js) . "'></script>";
	 */
	public static function JS($javascripts) {
		if (empty($javascripts)) throw new WireException('There were no javascript files specified to minify.');

		// support for FilenameArray eg. $config->scripts
		if ($javascripts instanceof FilenameArray) {
			$javascripts = (array) $javascripts->getIterator(); // Convert to array
		}

		$javascripts = (array) $javascripts;
		$javascripts = self::fileArray($javascripts, '.js');
		$cacheFile   = self::getCacheName($javascripts, (string) self::$configData['javascript_prefix'], '.js');
		$cachePath   = self::$assetsCacheDir . $cacheFile;
		$isDev       = (bool) self::$configData['development_mode'] == 1;
		//bd($javascripts, "JS() javascripts array");

		// Check if there is already a combined and cached file. If not, generate a new minified cache file.
		if (!file_exists($cachePath) || $isDev) {
			//bd($cachePath, "JS() cachePath does not exist, creating a new one");

			// Expire pages cache files if template caching is enabled.
			self::clearPagesCache();

			$js = '';
			foreach ($javascripts as $javascript) {
				//bd($javascript, "JS() processing javascript");
				$jsFileName = $javascript['absolute_path'];
				$content = file_get_contents($jsFileName);
				if ($content === false) continue;
				$content = self::stripSourceMapDirectives($content);

				if (!$isDev && !self::isMinified($jsFileName)) {
					$content = self::minifyJS($content);
				}

				$js .= $content . PHP_EOL;
			}

			$js = rtrim($js, PHP_EOL);

			self::writeCacheFile($cachePath, $js);
		}

		return self::buildAssetUrl($cacheFile, $isDev);
	}

	/**
	 * Minifies, combines, rewrites URLs, and caches one or more stylesheet files.
	 *
	 * Accepts a single stylesheet path or an array of them, processes
	 * each file (CSS or LESS), rewrites relative URLs to root-relative paths,
	 * minifies the resulting content, and stores the combined output in
	 * a cache file. Returns the public URL to the generated asset.
	 *
	 * LESS files are compiled using the included LESS parser. When running on
	 * virtual host configurations, import directories are adjusted to keep
	 * relative `@import` paths functional.
	 *
	 * @param string|array<int,string>|FilenameArray $stylesheets
	 *     A stylesheet path (e.g. `"css/main.css"`) or a list of stylesheet
	 *     paths relative to the template directory. A ProcessWire `FilenameArray`
	 *     (such as `$config->styles`) is also supported.
	 * @param array<string,string>|null $lessVars
	 *     Optional LESS variables to inject when compiling `.less` files.
	 *     Example: `['colorPrimary' => '#f00']`
	 * @return string
	 *     The public URL to the combined and minified stylesheet eg.
	 *     `/site/assets/aiom/css_94aa3617a3252dca4262cca287709c96.css`
	 * @example
	 *     // Combine two stylesheets
	 *     echo "<link rel='stylesheet' href='" . AIOM::CSS(['css/base.css', 'css/home.css']) . "'>";
	 * @example
	 *     // Compile LESS with variables
	 *     <link rel="stylesheet" href="<?= AIOM::CSS('css/styles.less', ['brandColor' => '#1e88e5']) ?>">
	 * @example
	 *     // Using PW config styles (FilenameArray)
	 *     <link rel="stylesheet" href="<?= AIOM::CSS($config->styles) ?>">
	 * @example
	 *     // Using own FilenameArray array
	 *     $css = new FilenameArray();
	 *     $css->add('css/base.css');
	 *     $css->add('css/home.css');
	 *     echo "<link rel='stylesheet' href='" . AIOM::CSS($css) . "'>";
	 */
	public static function CSS($stylesheets, $lessVars = null) {
		if (empty($stylesheets)) throw new WireException('There were no stylesheet files specified to minify.');

		// Support passing of $config->styles as argument which is of type FilenameArray
		if ($stylesheets instanceof FilenameArray) {
			$stylesheets = (array) $stylesheets->getIterator(); // Convert to array
		}

		$stylesheets = (array) $stylesheets;
		$stylesheets = self::fileArray($stylesheets, ['.css', '.less']);
		$cacheHashSuffix = (self::$configData['css_source_map'] == 1) ? '::cssmap=1' : '::cssmap=0';
		$cacheFile   = self::getCacheName($stylesheets, (string) self::$configData['stylesheet_prefix'], '.css', $cacheHashSuffix);
		$cachePath   = self::$assetsCacheDir . $cacheFile;
		$mapFile     = $cacheFile . '.map';
		$mapPath     = self::$assetsCacheDir . $mapFile;
		$isDev       = (bool) self::$configData['development_mode'] == 1;
		$config      = wire()->config;
		$generateCssSourceMap = (bool) (self::$configData['css_source_map'] == 1);
		//bd($stylesheets, "CSS() stylesheets array");

		// Check if there is already a combined and cached file. If not, generate a new minified cache file.
		if (!file_exists($cachePath) || $isDev) {
			//bd($cacheFile, "CSS() cachefile does not exist, creating a new one");

			// Expire pages cache files if template caching is enabled.
			self::clearPagesCache();

			$css = '';

			// Use a helper variable to hold the 'mixed' data from the superglobal
			$scriptName = self::toString($_SERVER['SCRIPT_NAME'] ?? ''); // /index.php
			$scriptFilename = self::toString($_SERVER['SCRIPT_FILENAME'] ?? ''); // C:\inetpub\wwwroot\index.php
			$documentRoot = self::toString($_SERVER['DOCUMENT_ROOT'] ?? ''); // C:\inetpub\wwwroot
			$isVirtualHost = $documentRoot !== str_replace($scriptName, '', $scriptFilename);

			// Processes each stylesheet by loading its content, compiling LESS if needed, rewriting URLs,
			// optionally minifying it, and appending the result to the combined CSS output.
			foreach ($stylesheets as $stylesheet) {
				//bd($stylesheet, "CSS() processing stylesheet");
				$cssFileName = $stylesheet['absolute_path'];
				$content = file_get_contents($cssFileName);
				if ($content === false) continue;

				// If LESS file then run LESS parser.
				if ($stylesheet['file_extension'] === 'less') {
					try {
						$lessParser = new \Less_Parser(['sourceMap' => $isDev]);
						if ($isVirtualHost) {
							$relDir = '/' . str_replace((string) $config->paths->root, '', dirname($cssFileName)) . '/';
							// LESS accepts dir=>path pairs here; PHPStan's signature is narrower.
							/** @phpstan-ignore-next-line argument.type */
							$lessParser->SetImportDirs([dirname($cssFileName) . '/' => $relDir]);
						}
						$lessParser->parse($content);
						if ($lessVars) $lessParser->ModifyVars($lessVars);
						$content = $lessParser->getCss();
					} catch(\Exception $e) {
						$content = '#_____LESS_____ERROR_____REPORT_____ {content:"' . $e->getMessage() . '"}';
					}
				}

				// Minify generated css, URL rewrite is needed independently of whether minification is needed
				if (!$isDev) {
					$content = \Minify_CSS_UriRewriter::rewrite($content, dirname($cssFileName), $isVirtualHost ? $config->paths->root : null);
					if (!self::isMinified($cssFileName)) {
						$content = self::minifyCSS($content);
					}
				}

				$css .= $content . PHP_EOL;
			}

			$css = rtrim($css, PHP_EOL);

			if ($generateCssSourceMap) {
				$mapJson = self::buildCssSourceMap($stylesheets, $cacheFile);
				self::writeRawCacheFile($mapPath, $mapJson);
				$css = self::appendCssSourceMapDirective($css, $mapFile);
			}

			self::writeCacheFile($cachePath, $css);
		}

		return self::buildAssetUrl($cacheFile, $isDev);
	}

	/**
	 * Minify a raw CSS string.
	 *
	 * Note: this method only minifies CSS text. It does not rewrite url(...) paths.
	 *
	 * @param string $css
	 * @return string
	 */
	public static function minifyCssString(string $css): string {
		return self::minifyCSS($css);
	}

	/**
	 * Minify a raw JavaScript string. Keep original content on minifier failure.
	 *
	 * @param string $js
	 * @return string
	 */
	public static function minifyJsString(string $js): string {
		return self::minifyJS($js);
	}

	/**
	 * Minify a raw HTML string.
	 *
	 * @param string $html
	 * @return string
		*/
	public static function minifyHtmlString(string $html): string {
		return self::minifyHTML($html);
	}

	/**
	 * Write generated asset content to cache and apply permissions.
	 *
	 * @param string $cachePath Absolute cache file path.
	 * @param string $content Generated JS/CSS content.
	 * @return void
	 */
	private static function writeCacheFile($cachePath, $content) {
		if (@file_put_contents($cachePath, self::generatorInformation($content), LOCK_EX) !== false) {
			/** @phpstan-ignore-next-line */
			if (self::DEBUG) self::log("$cachePath created");
			@wireChmod($cachePath);
		} else {
			self::log("ERROR: file_put_contents($cachePath) failed");
		}
	}

	/**
	 * Write raw content to cache file without generator header.
	 *
	 * @param string $cachePath Absolute cache file path.
	 * @param string $content Raw content.
	 * @return void
	 */
	private static function writeRawCacheFile($cachePath, $content) {
		if (@file_put_contents($cachePath, $content, LOCK_EX) !== false) {
			/** @phpstan-ignore-next-line */
			if (self::DEBUG) self::log("$cachePath created");
			@wireChmod($cachePath);
		} else {
			self::log("ERROR: file_put_contents($cachePath) failed");
		}
	}

	/**
	 * Build public URL for a generated asset file.
	 *
	 * @param string $cacheFile Cache filename.
	 * @param bool $isDev Development mode flag.
	 * @return string
	 */
	private static function buildAssetUrl($cacheFile, $isDev) {
		$assetDomain = self::getAssetDomain();
		$suffix = $isDev ? '?no-cache=' . time() : '';
		return $assetDomain . '/' . $cacheFile . $suffix;
	}

	/**
	 * Expire/clear aiom cache folder.
	 *
	 * @return int $numRemoved Number of deleted files
	 */
	private static function clearAiomCache() {
		$num = self::getNumberOfAiomCacheFiles(true); //true as parameter deletes the files
		$numRemoved = (int) $num['numberOfFiles'];

		$ret = wireRmdir(self::$aiomCacheDir, true);
		if ($ret === false) {
			self::log("ERROR: wireRmdir(" . self::$aiomCacheDir . ", true) failed");
		}
		wireMkdir(self::$aiomCacheDir);

		if (self::$configData['cache_enable'] == 1) {
			if (!is_file(self::$aiomCacheDir . 'aiom.enabled')) @file_put_contents(self::$aiomCacheDir . 'aiom.enabled', time());
		} else {
			if (is_file(self::$aiomCacheDir . 'aiom.enabled')) @unlink(self::$aiomCacheDir . 'aiom.enabled');
		}

		self::log("Deleted $numRemoved file(s) from " . self::$aiomCacheDir);
		return $numRemoved;
	}

	/**
	 * Expire/clear pages cache folder.
	 *
	 * @return int $numRemoved Number of deleted files.
	 */
	private static function clearPagesCache() {
		$numRemoved = 0;
		if (is_dir(self::$pagesCacheDir)) {
			$numRemoved = CacheFile::removeAll(self::$pagesCacheDir);
		}
		self::log("Deleted $numRemoved file(s) from " . self::$pagesCacheDir);
		return $numRemoved;
	}

	/**
	 * Expire/clear assets cache folder.
	 * Check the already cached CSS/JS files according to its lifetime.
	 * If the files already exist longer than the maximum time to live,
	 * they are deleted. The pages cache is also deleted if it least one
	 * cached CSS/JS file is deleted.
	 *
	 * @param boolean $force_all Force delete all the files in the cache folder.
	 * @return int $numRemoved Number of deleted files.
	 */
	private static function clearAssetsCache($force_all = false) {
		clearstatcache();

		$dir = self::$assetsCacheDir;
		if (!is_dir($dir)) return 0;

		$numRemoved1 = $numRemoved2 = 0;
		$now = time();
		$iterator = new \RecursiveIteratorIterator(
			new \RecursiveDirectoryIterator($dir, \FilesystemIterator::SKIP_DOTS),
			\RecursiveIteratorIterator::CHILD_FIRST
		);

		// Remove all files that are older than the maximum lifetime.
		foreach ($iterator as $cacheFile) {
			/** @var \SplFileInfo $cacheFile */
			if (!$cacheFile->isFile()) continue;
			$file = $cacheFile->getPathname();
			$mtime = filemtime($file);
			//bd($file, "clearAssetsCache() checking if file is expired");
			if ($mtime !== false && ((int) $mtime + (int) self::$configData['max_cache_lifetime'] < $now || $force_all)) {
				if (wireChmod($file) !== false) {
					if (!@unlink($file)) {
						self::log("ERROR: unlink($file) failed");
					} else {
						$numRemoved1++;
						/** @phpstan-ignore-next-line */
						if (self::DEBUG) self::log("Deleted $file");
						//bd($file, "clearAssetsCache() deleted file $file");
					}
				} else {
					self::log("ERROR: wireChmod($file) failed");
				}
			}
		}

		if ($numRemoved1 > 0) {
			self::log("Deleted $numRemoved1 file(s) from $dir");
		}

		//if any css/js file from assets cache is deleted, then invalidate the whole pages cache
		//since cached pages files could point to the just deleted css/js file
		if ($numRemoved1 > 0 || $force_all === true) {
			$numRemoved2 = self::clearPagesCache();
		}

		return $numRemoved1 + $numRemoved2;
	}

	/**
	 * Convert mixed values to string in a predictable way.
	 *
	 * @param mixed $value
	 * @return string
	 */
	private static function toString($value) {
		if (is_string($value)) return $value;
		if (is_int($value) || is_float($value) || is_bool($value)) return (string) $value;
		if ($value instanceof \Stringable) return (string) $value;
		return '';
	}

	/**
	 * Prepends a generation timestamp and module version comment.
	 *
	 * @param string $data CSS/JS code.
	 * @return string CSS/JS code with generation information.
	 */
	private static function generatorInformation($data) {
		$info = static::getModuleInfo();
		$version = wire()->sanitizer->text(self::toString($info['version'] ?? ''));
		return (!empty($data)) ? '/** Generated: ' . date('r') . ' // Powered by AIOM+ v' . $version . ' **/' . PHP_EOL . $data : '';
	}

	/**
	 * Appends a generation timestamp and module version comment.
	 *
	 * @param string $data HTML code.
	 * @return string HTML code with generation information.
	 */
	private static function generatorInformationHtml($data) {
		$info = static::getModuleInfo();
		$version = wire()->sanitizer->text(self::toString($info['version'] ?? ''));
		return (!empty($data)) ? $data . PHP_EOL . '<!-- Generated: ' . date('r') . ' // Powered by AIOM+ v' . $version . ' -->' : '';
	}

	/**
	 * Create a unique file name of the files to be combined.
	 *
	 * @param array<int,array{
	 *     absolute_path: string,
	 *     last_modified: int,
	 *     file_extension: string
	 * }> $files File-info entries returned by fileArray().
	 * @param string $prefix Prefix of the generated cache file e.g. "css_", "js_").
	 * @param string $ext File extension of the generated cache file (e.g. ".css", ".js").
	 * @return string Unique cache-file name, including prefix and extension, with an optional "_dev" suffix.
	 */
	private static function getCacheName($files, $prefix = 'css_', $ext = '.css', $extraHash = '') {
		$hash = md5(print_r($files, true) . (string) $extraHash);
		return (self::$configData['development_mode'] != 1) ? $prefix . $hash . $ext : $prefix . $hash . '_dev' . $ext;
	}

	/**
	 * Build a lightweight CSS source map JSON string.
	 *
	 * @param array<int, array{absolute_path: string,last_modified: int,file_extension: string}> $stylesheets
	 * @param string $cacheFile
	 * @return string
	 */
	private static function buildCssSourceMap(array $stylesheets, string $cacheFile): string {
		$config = wire()->config;
		$rootPath = rtrim((string) $config->paths->root, '/\\') . '/';
		$sources = [];

		foreach ($stylesheets as $stylesheet) {
			$path = (string) ($stylesheet['absolute_path'] ?? '');
			if ($path === '') continue;

			if (self::isRemote($path)) {
				$sources[] = $path;
				continue;
			}

			$normalized = str_replace('\\', '/', $path);
			$normalizedRoot = str_replace('\\', '/', $rootPath);
			if (strpos($normalized, $normalizedRoot) === 0) {
				$normalized = '/' . ltrim(substr($normalized, strlen($normalizedRoot)), '/');
			}

			$sources[] = $normalized;
		}

		$map = [
			'version' => 3,
			'file' => $cacheFile,
			'sources' => array_values(array_unique($sources)),
			'names' => [],
			'mappings' => '',
		];

		$json = json_encode($map, JSON_UNESCAPED_SLASHES);
		return is_string($json) ? $json : '{"version":3,"file":"' . $cacheFile . '","sources":[],"names":[],"mappings":""}';
	}

	/**
	 * Append CSS sourceMappingURL comment after removing previous directive.
	 *
	 * @param string $content
	 * @param string $mapFile
	 * @return string
	 */
	private static function appendCssSourceMapDirective(string $content, string $mapFile): string {
		$content = self::stripSourceMapDirectives($content);
		return rtrim($content) . PHP_EOL . '/*# sourceMappingURL=' . $mapFile . ' */';
	}

	/**
	 * Builds an array of file-info entries for the given asset files.
	 *
	 * @param array<int, string|array{
	 *     loadOn?: string,
	 *     files?: string|array<int, string>
	 * }> $asset_files List of asset file paths or conditional-loading rules
	 * @param string|array<int,string> $extension Allowed file extension(s)
	 * @return array<int, array{
	 *     absolute_path: string,
	 *     last_modified: int,
	 *     file_extension: string
	 * }>
	 */
	private static function fileArray($asset_files, $extension = '.css') {
		/* $asset_files =
		 *   - ['css/normal.css'],
		 *   - ['css1.css', 'css2.css'],
		 *   - [
		 *       ['loadOn' => 'template=basic-page', 'files' => ['css/one.css', 'css/two.css']]
		 *     ]
		 */
		$extension = is_array($extension) ? $extension : [$extension];
		$current_page_id = wire()->page->id;
		$assetFiles = [];

		foreach ($asset_files as $asset_file) {

			// check for conditional loading (loadOn) find all page ids based on the passed selector
			if (is_array($asset_file) && isset($asset_file['loadOn'], $asset_file['files'])) {
				$conditional_pages = wire()->pages->find($asset_file['loadOn'])->explode('id'); //findIDs() introduced in PW 3.0.133
				if (in_array($current_page_id, $conditional_pages, true)) {
					$files = is_array($asset_file['files']) ? $asset_file['files'] : [$asset_file['files']];
					foreach ($files as $file) {
						$assetFiles[] = self::getFileInfoArray($file, $extension);
					}
				}
			// No condition, always load
			} elseif (is_string($asset_file)) {
				$assetFiles[] = self::getFileInfoArray($asset_file, $extension);
			}

		}

		// Return array with valid file paths and timestamps without null or empty array entries
		return array_values(array_filter($assetFiles, fn($val) => !is_null($val)));
	}

	/**
	 * Creates a file-info record with absolute path, last-modified timestamp,
	 * and file extension. Returns null if the file does not exist, is remote
	 * and unavailable, or does not match allowed extensions.
	 *
	 * @param string $file path (or URL) to the asset file.
	 * @param array<int,string> $extension Allowed file extensions.
	 * @return array{
	 *     absolute_path: string,
	 *     last_modified: int,
	 *     file_extension: string
	 * }|null
	 */
	private static function getFileInfoArray($file, $extension) {

		$config = wire()->config;
		$file = trim((string) $file);
		if ($file === '') {
			self::log("ERROR: empty file path provided to getFileInfoArray()");
			return null;
		}

		// remove cache-busting parameters (?v=1.2.3#hash)
		$file = (string) preg_replace('/[?#].*$/', '', $file);
		$isRemote = self::isRemote($file);

		if (strpos($file, '/') === 0 && !$isRemote) {
			// absolute path, join with doc root
			$path = rtrim($config->paths->root, '/') . $file;
		} elseif ($isRemote && self::checkRemoteFileAccess($file)) {
			// remote file must be treated as existing
			// use max_cache_lifetime as a placeholder because filemtime() doesn't work with http requests
			return [
				'absolute_path'  => $file,
				'file_extension' => strtolower(pathinfo($file, PATHINFO_EXTENSION)),
				'last_modified'  => time() - (int) self::$configData['max_cache_lifetime']
			];
		} else {
			// relative path to templates dir
			$path = (self::$configData['directory_traversal'] != 1)
							? str_ireplace(['../', './', '%2e%2e%2f', '..%2f'], '', $config->paths->templates . $file)
							: $config->paths->templates . $file;
		}

		// File must exist locally
		if (!$isRemote && !file_exists($path)) {
			self::log("ERROR: $path does not exist");
			return null;
		}

		// Extension must match allowed list
		if (!self::hasNeedle($path, $extension)) {
			self::log("ERROR: invalid extension for $path");
			return null;
		}

		clearstatcache();

		$mtime = filemtime($path);

		return [
			'absolute_path'  => $path,
			'file_extension' => strtolower(pathinfo($path, PATHINFO_EXTENSION)),
			'last_modified'  => ($mtime !== false ? $mtime : time()),
		];
	}

	/**
	 * Check if external datasource is available.
	 *
	 * @param string $url
	 * @return bool
	 */
	private static function checkRemoteFileAccess($url) {
		/** @var WireHttp $http */
		$http = new WireHttp();
		$status = $http->status($url);

		// accept 2xx and 3xx
		if ($status >= 200 && $status < 400) {
			//if (self::DEBUG) self::log("INFO: Connection to external datasource succeeded: '$url' (HTTP $status)");
			//if (self::DEBUG) bd("INFO: Connection to external datasource succeeded: '$url' (HTTP $status)");
			return true;
		}

		self::log("ERROR: Connection to external datasource failed: '$url' (HTTP $status)");
		return false;
	}

	/**
	 * Returns the number of cache files and their size from /site/assets/aiom/
	 *
	 * @return array{
	 *    numberOfFiles: string,
	 *    bytesTotal: string
	 * }
	 */
	private static function getNumberOfAssetsCacheFiles() {
		$dir = self::$assetsCacheDir;
		$numberOfFiles = $bytesTotal = 0;

		if (!is_dir($dir)) wireMkdir($dir);
		$cacheFiles = new \RecursiveDirectoryIterator($dir, \RecursiveDirectoryIterator::SKIP_DOTS);

		// Number all the data together
		foreach ($cacheFiles as $cacheFile) {
			/** @var \SplFileInfo $cacheFile */
			if ($cacheFile->isFile()) {
				$numberOfFiles++;
				$bytesTotal += $cacheFile->getSize();
			}
		}

		return ['numberOfFiles' => number_format($numberOfFiles), 'bytesTotal' => self::wireBytesStr($bytesTotal)];
	}

	/**
	 * Returns the number of cache files and their size from /site/assets/cache/Page/
	 *
	 * @return array{
	 *    numberOfPages: string,
	 *    numberOfFiles: string,
	 *    bytesTotal: string
	 * }
	 */
	/*private static function getNumberOfPagesCacheFiles() {
		$dir = self::$pagesCacheDir;
		$numberOfFiles = $numberOfPages = $bytesTotal = 0;

		if (is_dir($dir)) {
			$cacheFiles = self::getDirContents($dir);

			foreach ($cacheFiles as $cacheFile) {
				$numberOfFiles++;
				$bytesTotal += @filesize($cacheFile);
			}

			$numberOfPages = count(scandir($dir)) - 2;
		};

		return ['numberOfPages' => number_format($numberOfPages), 'numberOfFiles' => number_format($numberOfFiles), 'bytesTotal' => self::wireBytesStr($bytesTotal)];
	}*/

	/**
	 * Returns the number of cache files and their size from /site/assets/cache/aiom/
	 *
	 * @param bool $delete Whether to delete the cache files while counting.
	 * @return array{
	 *    numberOfFiles: string,
	 *    bytesTotal: string
	 * }
	 */
	private static function getNumberOfAiomCacheFiles($delete = false) {
		$dir = self::$aiomCacheDir;
		$numberOfFiles = $bytesTotal = 0;

		if (is_dir($dir)) {
			$cacheFiles = self::getDirContents($dir);

			foreach ($cacheFiles as $cacheFile) {
				if (pathinfo($cacheFile, PATHINFO_BASENAME) !== 'aiom.enabled') {
					$numberOfFiles++;
					$bytesTotal += @filesize($cacheFile);
					if ($delete) @unlink($cacheFile);
				}
			}
		}

		return ['numberOfFiles' => number_format($numberOfFiles), 'bytesTotal' => self::wireBytesStr($bytesTotal)];
	}

	/**
	 * Create a list of files recursively.
	 *
	 * @param string $dir Directory path
	 * @return \Generator<string> Yields absolute file paths
	 */
	private static function getDirContents($dir) {
		$files = array_diff(@scandir($dir), ['.', '..']);

		foreach ($files as $value) {
			$path = $dir . DIRECTORY_SEPARATOR . $value;
			if (is_link($path)) continue; // skip symlinks to avoid loops
			$path = realpath($path);
			if ($path === false) continue; // entry might have disappeared
			if (!is_dir($path)) {
				yield $path;
			} else {
				yield from self::getDirContents($path);
				//yield $path; //skip directories
			}
		}

	}

	/**
	 * Empty /site/assets/aiom/ (cs/jss files cache) AND /site/assets/cache/Page/ (template cache)
	 * if you click Empty cache button in Minifying tab.
	 * Triggered by: &cache=clear
	 *
	 * @return void
	 */
	private static function clearAssetsCacheFromBackend() {
		// When assets cache dir /site/assets/aiom/, where minified CSS/JS files reside, is cleared,
		// you also have to clear the pages cache dir /site/assets/cache/Page/ where cached
		// pages (created by PageRender module) are stored, since referenced assets files no longer exist.
		// You could also clear /site/assets/cache/aiom/ where cache.json files points to cached pages,
		// but AIOMcache.php checks for that and if it can't find the cached page, it removes
		// cache.json file and also containing folder (maintenance).

		$numRemoved = self::clearAssetsCache(true);
		wire()->message(sprintf(__("Deleted %s cache file(s)."), $numRemoved));
		//wire()->notices->add(new NoticeMessage("AIOM+: " . sprintf(__("Deleted %s cache file(s)."), $numRemoved)));

		// redirect to module configuration.
		$url = wire()->modules->getModuleEditUrl(self::MODULENAME);
		wire()->session->redirect($url);
	}

	/**
	 * Empty /site/assets/cache/aiom/ (site structure with cache.json files)
	 * when you click "Empty cache" button in Caching tab.
	 * Triggered by: &pagecache=clear
	 *
	 * @return void
	 */
	private static function clearAiomCacheFromBackend() {
		$numRemoved = self::clearAiomCache();

		// delete pages cache too
		$numRemoved += self::clearPagesCache();
		wire()->message(sprintf(__("Deleted %s cache file(s) in total."), $numRemoved));
		//wire()->notices->add(new NoticeMessage("AIOM+: " . sprintf(__("Deleted %s cache file(s) in total."), $numRemoved)));

		// redirect to module configuration
		$url = wire()->modules->getModuleEditUrl(self::MODULENAME);
		wire()->session->redirect($url);
	}

	/**
	 * Check if the current template requires SSL.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	protected function checkSSL($event) {
		/** @var Page $page */
		$page = $event->object;
		$template = $page->template;
		if (!$template instanceof Template) {
			self::$templateUseSSL = false;
			return;
		}
		self::$templateUseSSL = ((int) $template->https === 1);
	}

	/**
	 * Get template files for a page.
	 *
	 * @param Page $page
	 * @return array<int,string> List of page template files (full path) or empty array
	 */
	protected function getTemplateFiles($page) {
		if (self::$configData['template_files'] === '') return [];

		//return if there is no cache file present for the rendered page
		$cacheFileObj = $this->getCacheFileObject($page);
		$cacheFileName = (string) $cacheFileObj;
		$cacheFileTimestamp = @filemtime($cacheFileName);
		if ($cacheFileTimestamp === false) return [];

		$config = wire()->config;
		/** @var Template $template */
		$template = $page->template;
		$templatesDir = $config->paths->templates;

		$tplFilesRaw = explode("\n", (string) self::$configData['template_files']);
		$tplFiles = [];

		foreach ($tplFilesRaw as $f) {
			if ($f === '{template_files}') {
				if ($template->filename != '') $tplFiles[] = $template->filename;
				if ($template->prependFile != '') $tplFiles[] = $template->prependFile;
				if ($template->appendFile != '') $tplFiles[] = $template->appendFile;
			} elseif ($f === '{config_template_files}') {
				if ($config->prependTemplateFile != '') $tplFiles[] = $templatesDir . $config->prependTemplateFile;
				if ($config->appendTemplateFile != '') $tplFiles[] = $templatesDir . $config->appendTemplateFile;
			} elseif ($f != '') {
				$tplFiles[] = $templatesDir . $f;
			}
		}

		//remove empty keys
		return array_filter($tplFiles);
	}

	/**
	 * Check if the template files (primary, append, prepend) are newer than
	 * cached file. If so, delete cache file.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	protected function checkTemplateFiles($event) {
		//return if template caching is off for all templates
		if (!is_dir(self::$pagesCacheDir)) return;

		clearstatcache();

		/** @var Page $page */
		$page = $event->object;
		$tplFiles = $this->getTemplateFiles($page);
		if (empty($tplFiles)) return;

		$cacheFile = $this->getCacheFileObject($page);
		$cacheFileName = (string) $cacheFile;
		$cacheFileTimestamp = @filemtime($cacheFileName);
		if ($cacheFileTimestamp === false) return;

		//bd($tplFiles, "checkTemplateFiles() tplFiles");
		//bd(date("Y-m-d H:i:s", $cacheFileTimestamp), "checkTemplateFiles() cacheFileName");
		foreach ($tplFiles as $f) {
			//bd(date("Y-m-d H:i:s", @filemtime($f)), "checkTemplateFiles() checking $f");
			if (is_file($f) && filemtime($f) > $cacheFileTimestamp) {
				//template file is newer than cachefile, invalidate (remove) cache files for the page
				//bd(date("Y-m-d H:i:s", filemtime($f)), "checkTemplateFiles() $f is newer than cachefile, remove page cache files");
				@$cacheFile->remove();
				break;
			}
		}

	}

	/**
	 * Returns the full asset domain used for serving cached/minified files.
	 *
	 * The domain may be overridden through the module’s configuration to enable
	 * domain sharding (e.g. serving assets from a cookie-less static subdomain).
	 * The method automatically selects the SSL or non-SSL shard based on the
	 * current template’s protocol setting and appends the asset cache directory.
	 * Must point to web root. Use a CNAME DNS record. If empty, the default URL
	 * will be used.
	 * Format: http(s)://static.mydomain.com (without a concluding slash)
	 *
	 * @return string  Fully qualified base URL for asset delivery.
	 */
	private static function getAssetDomain() {
		$cacheDir = wire()->config->urls->assets . self::CACHEDIR;
		if (self::$templateUseSSL === true) {
			return self::$configData['domain_sharding_ssl'] . $cacheDir;
		} else {
			return self::$configData['domain_sharding'] . $cacheDir;
		}
	}

	/**
	 * Ensures the provided value falls within MIN_CACHE_LIFETIME and MAX_CACHE_LIFETIME.
	 *
	 * @param string $value User supplied cache lifetime.
	 * @return string Sanitized cache lifetime.
	 */
	private function sanitizeNumericCacheTime($value) {
		$v = intval($value);
		if ($v < self::MIN_CACHE_LIFETIME || $v > self::MAX_CACHE_LIFETIME) {
			wire()->warning(sprintf("Invalid cache lifetime %s, the default value of %s will be used.", $v, self::DEFAULT_CACHE_LIFETIME));
			$v = self::DEFAULT_CACHE_LIFETIME;
		}
		return (string) $v;
	}

	/**
	* Sanitizes a URL-like string and removes trailing slash.
	*
	* @param string $url Input URL string.
	* @return string Sanitized URL without trailing slash.
	*/
	private function validateURL($url) {
		$sanitizedUrl = wire()->sanitizer->url($url);
		//if (!filter_var($url, FILTER_VALIDATE_URL)) return '';
		return rtrim($sanitizedUrl, '/');
	}

	/**
	 * Checks if the url is absolute or relative.
	 *
	 * @param string $url The URL to be checked.
	 * @return bool True if URL is remote.
	 */
	private static function isRemote($url) {
		$u = ltrim($url);
		if (strpos($u, '//') === 0) return true; // protocol-relative (must be at start)
		if (preg_match('/^[a-z]:[\/\\\\]/i', $u)) return false; // Windows drive path is local, not remote
		return (bool) preg_match('/^[a-z][a-z0-9+\-.]*:/i', $u); // RFC 3986
	}

	/**
	 * Checks if ".min" or "-min" at the end of the file name exists.
	 *
	 * @param string $absolute_path Path with filename.
	 * @return bool
	 */
	private static function isMinified($absolute_path) {
		// Match: start or [.-], then min, then .js/.css, at the end
		return preg_match('/(?:^|[.-])min\.(?:js|css)$/', strtolower(basename($absolute_path))) === 1;
	}

	/**
	 * Check if an array with given extension matches in a string.
	 *
	 * @param string $haystack Haystack to search
	 * @param array<int,string|null> $arrayNeedles Array with extension to search
	 * @return bool
	 */
	private static function hasNeedle($haystack, $arrayNeedles) {
		foreach ($arrayNeedles as $needle) {
			$needle = (string) $needle;
			if ($needle !== '' && stripos($haystack, $needle) !== false) return true;
		}
		return false;
	}

	/**
	 * Minify HTML but protect textareas, code fields and conditional comments.
	 * Optional minify stylesheets and javascript inside the HTML.
	 *
	 * @param  HookEvent $event
	 * @return void
	 */
	protected function HTML($event) {
		//self::log("HTML() start");
		//bd('HTML() start');
		//$timer = Debug::timer();

		/** @var Page $page */
		$page = $event->object;
		/** @var string $html */
		$html = $event->return;
		$isDev = self::$configData['development_mode'] == 1;
		$skipMinify = (bool) $page->get('skip_minify');
		$htmlChanged = false;

		if (!$isDev && !$skipMinify && (self::$configData['css_minify'] == 1 || self::$configData['js_minify'] == 1)) {
			// array of placeholders (shields) that will be protected from preg_replace
			// eg. "<script>something...</script>" -> ["###AIOM_SHIELD_0###"]
			$patterns = [
				'<!--.*?-->', //comments
				'<style\b[^>]*>.*?<\/style>', //inline CSS blocks
				'<script\b(?![^>]*?\bsrc\s*=)[^>]*>.*?<\/script>', //scripts without a src attribute
			];

			$shields = [];
			$htmlProc = self::shield($html, $patterns, $shields);
			//bd($shields, "HTML() shields on CSS/JS");

			if (self::$configData['css_minify'] == 1) {
				$linkPattern = '/<link(?=[^>]*?\brel\s*=\s*["\']?\bstylesheet\b["\']?)[^>]*>/is';
				$htmlProc = self::processAssets($htmlProc, $linkPattern, 'href', 'CSS');
				//bd($htmlProc, "HTML() css");
			}

			if (self::$configData['js_minify'] == 1) {
				$scriptPattern = '/<script(?=[^>]*?\bsrc\s*=\s*["\']?[^"\'\s>]+)[^>]*>/is';
				$htmlProc = self::processAssets($htmlProc, $scriptPattern, 'src', 'JS');
				//bd($htmlProc, "HTML() js");
			}

			$html = self::unshield($htmlProc, $shields);
			$htmlChanged = true;
		}

		if (!$isDev && !$skipMinify && self::$configData['html_minify'] == 1) {
			$html = self::minifyHTML($html);
			$html = self::generatorInformationHtml($html);
			$htmlChanged = true;
		}

		if (self::$configData['cache_enable'] == 1 && $this->isPageCachable($page)) {
			$this->createCache($page);
		}

		/** @var Template $template */
		$template = $page->template;

		//if template has caching enabled, pageRender method already saved the cache file
		if ($htmlChanged && $template->cache_time > 0) {
			//wire()->session->PageRenderNoCachePage == $page->id
			$cacheFile = $this->getCacheFileObject($page);
			@$cacheFile->save($html);
			/** @phpstan-ignore-next-line */
			if (self::DEBUG) self::log((string) $cacheFile . " updated");
			//bd('HTML() '. (string) $cacheFile . ' updated');
		}

		$event->return = $html;
		//Debug::saveTimer($timer, 'finish');
		//echo "timer:" . Debug::getSavedTimer($timer);
	}

	/**
	 * Protects targeted HTML blocks by replacing them with unique placeholder tokens
	 * to shield them from manipulation.
	 *
	 * @param string $html The original HTML content to scan and protect.
	 * @param array<int,string> $patterns An array of regex fragments (without delimiters).
	 * @param array<string,string> &$shields Array with placeholder tokens as keys and matched HTML blocks as values.
	 * @return string Modified HTML where all matched blocks have been replaced with tokens.
	 */
	private static function shield(string $html, array $patterns, array &$shields): string {
		$regex = '/' . implode('|', $patterns) . '/is';

		// use ?? $html to fall back to the original string if regex fails
		return preg_replace_callback($regex, function($matches) use (&$shields) {
						 $token = "###AIOM_SHIELD_" . count($shields) . "###";
						 $shields[$token] = $matches[0];
						 return $token;
		}, $html) ?? $html;
	}

	/**
	 * Restores previously shielded HTML blocks back into the provided content.
	 *
	 * @param string $html The HTML content containing placeholder tokens.
	 * @param array<string,string> $shields Array of placeholder tokens as produced by `shield()`.
	 * @return string The HTML content with all shield tokens replaced.
	 */
		private static function unshield(string $html, array $shields): string {
		return !empty($shields) ? strtr($html, $shields) : $html;
	}

	/**
	 * Processes asset tags (e.g., <link href="..."> or <script src="...">) inside HTML.
	 *
	 * It first matches asset-containing tags using the supplied `$tagPattern` (e.g. "<script" or
	 * "<link>"). Then it extracts the attribute given by `$attrName` (e.g. "href" or "src") and
	 * rewrites its value by calling JS() or CSS() methods.
	 *
	 * @param string $html The raw HTML content containing asset tags to be processed.
	 * @param string $tagPattern Full regex (with delimiters) match each HTML tag
	 *     containing an asset attribute (e.g., <link>, <script>). Each match becomes
	 *     one processing unit for the inner callback.
	 * @param string $attrName Name of the HTML attribute "href" or "src".
	 * @param string $methodName Name of a class method ("CSS", "JS", etc.) that rewrites the path.
	 *     Will be called as:  self::{$methodName}($path)
	 * @return string
	 *     The HTML content with updated asset paths, excluding:
	 *     - commented-out tags,
	 *     - remote URLs,
	 *     - paths already inside the cache directory.
	 */
	private static function processAssets($html, $tagPattern, $attrName, $methodName) {
		$cdir = self::$assetsCacheDir;

		return preg_replace_callback($tagPattern, function ($tagMatch) use ($attrName, $methodName, $cdir) {
			$fullTag = $tagMatch[0];
			$attrPattern = '/\b' . $attrName . '\s*=\s*(["\']?)(?P<path>[^"\'\s>]+)\1/i';

			return preg_replace_callback($attrPattern, function ($attrMatch) use ($cdir, $methodName) {
				$path = $attrMatch['path'];

				// skip over files already in cache and ignore remote files
				if (strpos($path, $cdir) !== false || self::isRemote($path)) {
					return $attrMatch[0];
				}

				// call JS() or CSS()
				$newPath = self::{$methodName}($path);

				return str_replace($path, $newPath, $attrMatch[0]);
			}, $fullTag) ?? $fullTag;
		}, $html) ?? $html;
	}

	/**
	 * Minify HTML in a conservative way.
	 * Based on MinifyPageRender module logic.
	 * @param string $html HTML content to process.
	 * @return string Minified HTML.
	 */
	private static function minifyHTML($html) {
		$mode = self::$configData['html_minify_mode'] ?? 'safe';

		if ($mode === 'legacy') {
			$patterns = [
				'<(script|textarea|pre|code)\\b[^>]*>.*?<\\/\\1>',
				'<!--\\s*(?:vue-|alpine-|svelte-|ko\\s|__|\\b@|#|slot-).*?-->',
			];

			$shields = [];
			$htmlProc = self::shield($html, $patterns, $shields);

			$minifyMap = [
				'/<!--.*?-->/s' => '',
				'/[ \\t]{2,}/' => ' ',
				'/>\\s+</' => '><',
				'/^\\s+/m' => '',
				'/\\s+$/m' => '',
			];

			$htmlProc = (string) preg_replace(array_keys($minifyMap), array_values($minifyMap), $htmlProc);
			$htmlProc = (string) preg_replace("/(\\r?\\n|\\r)/", "", $htmlProc);

			return trim(self::unshield($htmlProc, $shields));
		}

		$replace = [
			'/\>[^\S ]+/s' => '>',
			'/[^\S ]+\</s' => '<',
			'/([\t ])+/s' => ' ',
			'/^([\t ])+/m' => '',
			'/([\t ])+$/m' => '',
			'~//[a-zA-Z0-9 ]+$~m' => '',
			'/[\r\n]+([\t ]?[\r\n]+)+/s' => "\n",
			'/\>[\r\n\t ]+\</s' => '><',
			'/}[\r\n\t ]+/s' => '}',
			'/}[\r\n\t ]+,[\r\n\t ]+/s' => '},',
			'/\)[\r\n\t ]?{[\r\n\t ]+/s' => '){',
			'/,[\r\n\t ]?{[\r\n\t ]+/s' => ',{',
		];

		$result = preg_replace(array_keys($replace), array_values($replace), $html);
		return is_string($result) ? $result : $html;
	}

	/**
	 * Minifies CSS content by removing comments and unnecessary
	 * whitespace, without affecting data URLs.
	 *
	 * @author Gemini, M365Copilot & Github copilot :-)
	 * @param string $css CSS code to minify.
	 * @return string Minified CSS code.
	 */
	private static function minifyCSS($css) {
		//$cssMin = new \tubalmartin\CssMin\Minifier();
		//$content = $cssMin->run($css);

		// remove comments except /*! ... */
		$css = (string) preg_replace('~/\*(?!\!)(?:.|\n)*?\*/~', '', $css);

		// normalize & collapse whitespace
		$css = str_replace(["\r\n", "\r"], "\n", $css);
		$css = (string) preg_replace('/\s+/', ' ', $css);

		// remove spaces around common delimiters
		$css = (string) preg_replace(
			[
				'/\s*{\s*/', '/\s*}\s*/', '/\s*;\s*/',
				'/\s*:\s*/', '/\s*,\s*/', '/;}/',
			], [
				'{', '}', ';', ':', ',', '}'
			], $css);

		// remove semicolons that are immediately followed by optional whitespace and a
		// closing brace, preserving semicolons that are part of the CSS structure
		$css = (string) preg_replace('/;(\s*})/', '$1', $css);

		return trim($css);
	}

	/**
	 * Minifies JavaScript by removing comments and superfluous
	 * whitespace while preserving syntax-sensitive parts.
	 *
	 * @param string $js JavaScript code to minify.
	 * @return string Minified JavaScript code.
	 */
	private static function minifyJS($js) {
		// don't attempt to minify JS using regex
		try {
			return (string) \JShrink\Minifier::minify($js);
		} catch (\Exception $e) {
			self::log('WARNING: minifyJS() fallback to original JS: ' . $e->getMessage());
			return $js;
		}
	}

	/**
	 * Remove source map directives from JavaScript content.
	 *
	 * @param string $content
	 * @return string
	 */
	private static function stripSourceMapDirectives($content) {
		$content = preg_replace('/^\s*\/\/#\s*sourceMappingURL=.*$/mi', '', (string) $content);
		$content = preg_replace('/\/\*#\s*sourceMappingURL=.*?\*\//mi', '', (string) $content);
		return is_string($content) ? trim($content) : '';
	}

	/**
	 * Render cache file in /site/assets/cache/aiom/
	 *
	 * @param Page $page
	 * @return void
	 */
	protected function createCache($page) {
		$cacheFile = $this->getCacheFile($page);
		$file = $this->getAiomCacheDir($page) . 'cache.json'; // /site/assets/cache/aiom/one/page10/cache.json

		// convert array to json object and write to cache file
		$json = json_encode($cacheFile, JSON_FORCE_OBJECT);
		//@unlink($file);
		$result = @file_put_contents($file, $json, LOCK_EX);

		if ($result === false) {
			self::log("ERROR: create file $file failed");
		} else {
			//self::log("$file created");
		}
	}

	/**
	 * Return aiom cache directory. If page is provided, then cache directory for the page is returned
	 * and directory structure for the page url is created.
	 *
	 * @param Page|null $page
	 * @return string
	 */
	protected function getAiomCacheDir($page = null) {
		// $page->path and $page->url starts with /
		$cacheDir = rtrim(self::$aiomCacheDir, '/');

		/** @var Page|null $page */
		if ($page && $page->id) {
			//$cacheDir .= $page->path; // /subfolder/page/one/
			$cacheDir .= $page->url;    // /page/one/
			/** @var Template $template */
			$template = $page->template;
			if ($template->allowPageNum && wire()->input->pageNum > 1) {
				$cacheDir .= wire()->config->pageNumUrlPrefix . wire()->input->pageNum . '/';
			}
		}

		$cacheDir = rtrim($cacheDir, '/') . '/';
		if (!is_dir($cacheDir) && self::$configData['cache_enable'] == 1) {
			$result = wireMkdir($cacheDir, true);
			if ($result) {
				//self::log("$cacheDir created");
			} else {
				self::log("ERROR: $cacheDir create failed");
			}
		}

		return $cacheDir;
	}

	/**
	 * Return CacheFile object
	 *
	 * @param Page $page
	 * @return CacheFile
	 */
	protected function getCacheFileObject($page) {
		/** @var Template $template */
		$template = $page->template;
		$config = wire()->config;
		$options = [
			'prependFile' => $template->noPrependTemplateFile ? null : $config->prependTemplateFile,
			'prependFiles' => $template->prependFile ? [$template->prependFile] : [],
			'appendFile' => $template->noAppendTemplateFile ? null : $config->appendTemplateFile,
			'appendFiles' => $template->appendFile ? [$template->appendFile] : [],
		];
		/** @var PageRender $pageRender */
		$pageRender = wire()->modules->get('PageRender');

		return $pageRender->getCacheFile($page, $options);
	}

	/**
	 * Return cache filename array.
	 *
	 * @param Page $page
	 * @return array{
	 *     0: string,
	 *     1: int,
	 *     2: int,
	 *     3: string,
	 *     4: array<int,string>
	 * }
	 */
	protected function getCacheFile($page) {
		$cacheFileObj = $this->getCacheFileObject($page);
		$cacheFileStr = (string) $cacheFileObj;
		$cacheFileArr = (array) $cacheFileObj;
		$cacheTime = $cacheFileArr[chr(0).'*'.chr(0).'cacheTimeSeconds']; //protected property
		//should we get cache time from template?
		//$cacheTime = (int) $page->template->cache_time;
		//$cacheTime = (int) $page->template->cacheTime; this is an alias for cache_time
		$cacheExpireTime = time() + $cacheTime;
		$cacheExpireDate = date("Y-m-d H:i:s", $cacheExpireTime); //not used
		$tplFiles = $this->getTemplateFiles($page);

		return [
			$cacheFileStr,    //eg. /site/assets/cache/Page/1/page2_1234.cache
			$cacheTime,       //eg. 3600
			$cacheExpireTime, //eg. 1583141543
			$cacheExpireDate, //eg. 2020-02-20 21:57:03
			$tplFiles         //eg. /site/templates/basic-page.php
		];
	}

	/**
	 * Check if page can be cached.
	 *
	 * @param Page $page
	 * @return bool
	*/
	protected function isPageCachable($page) {
		if (wire()->user->isLoggedin()) return false;
		if (isset($_COOKIE['wire_challenge']) || isset($_COOKIE['wires_challenge'])) return false;
		if (count($_GET) || count($_POST)) return false;
		/** @var Template $template */
		$template = $page->template;
		if ($template->cache_time < 1) return false;

		return true;
	}

	/**
	 * Convert seconds to human readable time.
	 *
	 * @author: Tabea David
	 * @param int $inputSeconds
	 * @return string
	 */
	private static function seconds2human($inputSeconds) {
		$inputSeconds = (int)$inputSeconds;

		$secondsInAMinute = 60;
		$secondsInAnHour = 3600;
		$secondsInADay = 86400;

		// extract days
		$days = floor($inputSeconds / $secondsInADay);

		// extract hours
		$hourSeconds = $inputSeconds % $secondsInADay;
		$hours = floor($hourSeconds / $secondsInAnHour);

		// extract minutes
		$minuteSeconds = $hourSeconds % $secondsInAnHour;
		$minutes = floor($minuteSeconds / $secondsInAMinute);

		// extract the remaining seconds
		$remainingSeconds = $minuteSeconds % $secondsInAMinute;
		$seconds = ceil($remainingSeconds);

		$units = [
			'day' => (int) $days,
			'hour' => (int) $hours,
			'minute' => (int) $minutes,
			'second' => (int) $seconds
		];

		$out = [];
		foreach ($units as $unit => $amount) {
			if (!$amount) continue;
			$u = $amount === 1 ? $unit : "{$unit}s";
			$out[] = "{$amount} " . self::getUnit($u);
		}

		//if everything was zero (e.g., input was 0 or <1 sec), ensure "0 sec"
		if (!$out) {
			return '0 ' . self::getUnit('seconds');
		}

		return implode(' ', $out);
	}

	/**
	 * Get Unit
	 *
	 * @author: Tabea David
	 * @param string $key
	 * @return string
	 */
	private static function getUnit($key) {
		$units = [
			'day' => __('day'),
			'hour' => __('hour'),
			'minute' => __('min'),
			'second' => __('sec'),
			'days' => __('days'),
			'hours' => __('hours'),
			'minutes' => __('min'),
			'seconds' => __('sec'),
		];

		return $units[$key] ?? '';
	}

	/**
	 * Given a quantity of bytes, return readable string using 1024 steps and kB/MB labels (legacy).
	 * Intentionally made simple.
	 *
	 * @param int $bytes
	 * @return string
	 */
	private static function wireBytesStr($bytes) {
		$label  = ['B', 'kB', 'MB', 'GB', 'TB', 'PB']; // 5 = (count($label) - 1
		for ($i = 0; $bytes >= 1024 && $i < 5; $i++) $bytes /= 1024;

		return round($bytes) . ' ' . $label[$i];
	}

	/**
	 * Logs a message to the aiom.txt file.
	 *
	 * @param string $str Log message
	 * @return void
	 */
	private static function log($str) {
		wire()->log->save('aiom', $str);
	}

}

/**
 * Short-Syntax
 */
class AIOM extends AllInOneMinify {}
